# 复制到：
#   ~/Library/Application Support/minmeng-canzheng-agent/.env
# 或仓库本地 .env（已在 .gitignore）
# 切勿提交真实 Webhook / 密钥

# —— 通道 A：自定义机器人 Webhook（可选）——
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# FEISHU_WEBHOOK_SECRET=

# —— 通道 B：应用机器人 + lark-cli（推荐用 CLI 一键配置）——
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# FEISHU_PUSH_ALWAYS=1
# FEISHU_SITE_URL=https://minmengxhw-cpu.github.io/minmeng-canzheng-agent/
# LARK_CLI=/Users/你/.local/bin/lark-cli

# 群邀请链接（扫码入群用，可公开挂在网站上）
# FEISHU_JOIN_URL=https://applink.feishu.cn/client/chat/chatter/add_by_link?link_token=xxxx
